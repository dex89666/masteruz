// ════════════════════════════════════════════════
// ПАРТНЁРСКИЕ МАГАЗИНЫ (СТРОЙМАТЕРИАЛЫ)
// ════════════════════════════════════════════════

enum StoreStatus {
  PENDING
  ACTIVE
  REJECTED
  SUSPENDED
}

enum PartnerRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model PartnerStore {
  id              String      @id @default(uuid())
  name            String
  nameUz          String?     @map("name_uz")
  nameEn          String?     @map("name_en")
  slug            String      @unique
  description     String?
  descriptionUz   String?     @map("description_uz")
  descriptionEn   String?     @map("description_en")
  logoUrl         String?     @map("logo_url")
  coverUrl        String?     @map("cover_url")
  phone           String
  email           String?
  website         String?
  telegramUsername String?    @map("telegram_username")
  contactPerson   String      @map("contact_person")
  address         String?
  city            String?
  district        String?
  latitude        Float?
  longitude       Float?
  storeCategory   String      @map("store_category") // building-materials, tools, paints, plumbing, electrical, finishing, furniture-materials
  rating          Float       @default(0)
  reviewCount     Int         @default(0) @map("review_count")
  status          StoreStatus @default(PENDING)
  isVerified      Boolean     @default(false) @map("is_verified")
  workingHours    String?     @map("working_hours")
  deliveryAvailable Boolean   @default(false) @map("delivery_available")
  discountForMasters Decimal?  @map("discount_for_masters") @db.Decimal(5, 2) // Скидка для мастеров платформы (%)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  products        StoreProduct[]
  reviews         StoreReview[]

  @@index([storeCategory])
  @@index([status])
  @@index([city])
  @@map("partner_stores")
}

model StoreProduct {
  id           String   @id @default(uuid())
  storeId      String   @map("store_id")
  name         String
  nameUz       String?  @map("name_uz")
  nameEn       String?  @map("name_en")
  description  String?
  descriptionUz String? @map("description_uz")
  descriptionEn String? @map("description_en")
  price        Decimal  @db.Decimal(12, 2)
  unit         String?  // шт, м², кг, литр, рулон
  imageUrl     String?  @map("image_url")
  category     String   // category of product
  inStock      Boolean  @default(true) @map("in_stock")
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  store PartnerStore @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, category])
  @@map("store_products")
}

model StoreReview {
  id        String   @id @default(uuid())
