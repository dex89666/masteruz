// ════════════════════════════════════════════════
// СИСТЕМА ПРИВИЛЕГИРОВАННЫХ ДОЛЖНОСТНЫХ ЛИЦ
// И ИНЦЕНТИВИЗАЦИЯ (для чиновников, начальников ЖЭКа и т.д.)
// ════════════════════════════════════════════════

// Статусы привилегированного профиля
enum PrivilegeStatus {
  PENDING        // Ожидание проверки
  ACTIVE         // Активен
  SUSPENDED      // Приостановлен
  REVOKED        // Отозван
}

// Типы привилегированных лиц
enum PrivilegeType {
  OFFICIAL        // Государственный чиновник
  BUILDING_HEAD   // Начальник жилого дома, ЖЭК, УК
  BUSINESS_OWNER  // Владелец/директор предприятия
  DISTRICT_HEAD   // Начальник объединённого квартала/округа
}

// Модель: Профиль привилегированного должностного лица
model PrivilegedOfficialProfile {
  id                String            @id @default(uuid())
  userId            String            @unique @map("user_id")
  // Документ/реквизиты верификации
  organizationName  String            @map("organization_name")    // ТОО "ЖЭК №3", Алмалинский жилой комплекс
  position          String                                          // "Начальник", "Директор", "Уполномоченный"
  documentNumber    String?           @map("document_number")       // Номер приказа, справки
  documentUrl       String?           @map("document_url")          // URL скана документа
  privilegeType     PrivilegeType                                    // Категория привилегий
  // Статус и жизненный цикл
  status            PrivilegeStatus   @default(PENDING)
  statusReason      String?           @map("status_reason")         // Причина отказа / приостановки
  // Привилегии
  canFastTrack      Boolean           @default(true) @map("can_fast_track")      // Ускорить своё заявления в очереди
  canAssignMaster   Boolean           @default(true) @map("can_assign_master")   // Назначить мастера
  canOverrideSla    Boolean           @default(false) @map("can_override_sla")  // Переопределить SLA
  canAccessAnalytics Boolean          @default(true) @map("can_access_analytics") // Видеть метрики
  // Сроки действия и отсчёт
  expiresAt         DateTime?         @map("expires_at")
  renewalNotifSentAt DateTime?        @map("renewal_notif_sent_at")
  // KPI и мотивация
  targetSlaScore    Float             @default(85.0) @map("target_sla_score")   // % заказов в срок
  targetSatisfaction Float            @default(4.0) @map("target_satisfaction") // средняя оценка 1-5
  // Бонусные программы
  monthlyBonusPool  Decimal           @default(0) @map("monthly_bonus_pool") @db.Decimal(12, 2) // Пул на месяц (сум)
  bonusPercentage   Float             @default(5.0) @map("bonus_percentage")    // % от сэкономленной суммы
  // Лимиты действий за день/месяц
  dailyFastTrackLimit Int             @default(5) @map("daily_fast_track_limit")
  dailyFastTrackUsed Int              @default(0) @map("daily_fast_track_used")
  dailyFastTrackResetAt DateTime?     @map("daily_fast_track_reset_at")
  // Аудит
  approvedBy        String?           @map("approved_by")           // ID админа, одобрившего статус
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  approver          User?             @relation("OfficialApprover", fields: [approvedBy], references: [id])
  actions           PrivilegedAction[]
  kpiRecords        KPIRecord[]
  orderPriorities   OfficialOrderPriority[]

  @@index([status, expiresAt])
  @@index([privilegeType])
  @@index([userId])
  @@map("privileged_official_profiles")
}

// Модель: История и аудит действий привилегированного лица
model PrivilegedAction {
  id                String   @id @default(uuid())
  officialId        String   @map("official_id")
  action            String                         // 'FAST_TRACKED', 'ASSIGNED_MASTER', 'COMMENT_ADDED', 'PRIORITY_SET'
  targetEntityType  String   @map("target_entity_type")  // 'ORDER', 'USER', 'MASTER'
  targetEntityId    String   @map("target_entity_id")    // ID заказа, пользователя, мастера
  description       String?                        // Описание действия
  metadata          Json?                          // Доп. данные: {orderId, masterId, reason, etc}
  ipAddress         String?  @map("ip_address")
  userAgent         String?  @map("user_agent")
  createdAt         DateTime @default(now()) @map("created_at")

  official PrivilegedOfficialProfile @relation(fields: [officialId], references: [id], onDelete: Cascade)

  @@index([officialId, createdAt])
  @@index([action, createdAt])
  @@index([targetEntityType, targetEntityId])
  @@map("privileged_actions")
}

// Модель: KPI и метрики по привилегированным лицам
model KPIRecord {
  id                String   @id @default(uuid())
  officialId        String   @map("official_id")
  period            String                         // '2024-06', '2024-Q2' (год-месяц или квартал)
  // Метрики SLA: % заказов завершено в срок
  totalOrders       Int      @default(0) @map("total_orders")
  onTimeOrders      Int      @default(0) @map("on_time_orders")
  slaScore          Float    @default(0.0) @map("sla_score")        // % (0–100)
  // Метрики качества: средняя оценка клиентов (1–5звезд)
  avgRating         Float    @default(0.0) @map("avg_rating")
  ratingCount       Int      @default(0) @map("rating_count")
  // Метрики скорости решения жалоб
  totalComplaints   Int      @default(0) @map("total_complaints")
  resolvedComplaints Int     @default(0) @map("resolved_complaints")
  avgResolutionDays Float    @default(0.0) @map("avg_resolution_days")
  // Финансовые метрики
  totalOrderAmount  Decimal  @default(0) @map("total_order_amount") @db.Decimal(12, 2)
  savings           Decimal  @default(0) @map("savings") @db.Decimal(12, 2)  // Сумма сэкономленная по SLA
  bonusEarned       Decimal  @default(0) @map("bonus_earned") @db.Decimal(12, 2)
  // Status
  status            String   @default("PRELIMINARY")  // PRELIMINARY, FINAL, VOIDED
  lockedAt          DateTime? @map("locked_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  official PrivilegedOfficialProfile @relation(fields: [officialId], references: [id], onDelete: Cascade)

  @@unique([officialId, period])
  @@index([officialId, period])
  @@index([period])
  @@map("kpi_records")
}

// Модель: Приоритет к заказу, назначенный привилегированным лицом
model OfficialOrderPriority {
  id                String   @id @default(uuid())
  orderId           String   @map("order_id")
  officialId        String   @map("official_id")
  priorityLevel     Int                            // 1 = критично, 2 = высокий, 3 = нормальный
  reason            String?                        // Причина приоритизации
  // SLA для этого заказа (переопределение глобального)
  customSlaHours    Int?     @map("custom_sla_hours")     // Например: 4 часа вместо 24
  bonusAmount       Decimal? @map("bonus_amount") @db.Decimal(12, 2) // Доп. награда за ускорение
  createdAt         DateTime @default(now()) @map("created_at")

  official PrivilegedOfficialProfile @relation(fields: [officialId], references: [id], onDelete: Cascade)

  @@unique([orderId, officialId])
  @@index([officialId, createdAt])
  @@index([priorityLevel])
  @@map("official_order_priorities")
}

// Модель: Настройки мотивации для привилегированных (кастомизируются админом)
model MotivationSetting {
  id                String   @id @default(uuid())
  // Правые привилегии для разных уровней
  privilegeType     PrivilegeType    @unique @map("privilege_type")
  // Пороги для достижений и бонусов
  slaThresholdPct   Float   @default(85.0) @map("sla_threshold_pct")      // % для "Отличный SLA"
  satisfactionMin   Float   @default(4.0) @map("satisfaction_min")        // минимум для бонуса
  // Бонус-структура
  baseBonusPercentage Float @default(5.0) @map("base_bonus_percentage")  // % от экономии
  slaBonusBoost     Float  @default(1.5) @map("sla_bonus_boost")         // множитель за хороший SLA
  // Приоритеты и ускорение
  fastTrackLimit    Int     @default(5) @map("fast_track_limit")         // Номер ускорений в день
  maxCustomSlaHours Int     @default(4) @map("max_custom_sla_hours")     // max SLA override
  // Памятки и напоминания
  renewalDaysBefore Int     @default(30) @map("renewal_days_before")     // Напомнить за N дней до истечения
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("motivation_settings")
}

