// ════════════════════════════════════════════════
// УВЕДОМЛЕНИЯ
// ════════════════════════════════════════════════

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  data      Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ─── Журнал доставки push-уведомлений ────────────────────
// Записывается при каждой попытке разослать новый заказ мастерам.
// Позволяет диагностировать «почему мастер не получил пуш» прямо из админки.
model NotificationDeliveryLog {
  id          String   @id @default(uuid())
  orderId     String   @map("order_id")
  userId      String   @map("user_id")
  channel     String   // 'in_app' | 'telegram'
  status      String   // 'success' | 'failed' | 'skipped'
  reason      String?  // 'no_telegram_id' | 'bot_blocked' | 'chat_not_found' | etc.
  errorCode   Int?     @map("error_code")
  description String?
  matchMode   String?  @map("match_mode") // 'category' | 'fallback_all_masters'
  distanceKm  Float?   @map("distance_km")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("notification_delivery_logs")
}

// ════════════════════════════════════════════════
// ЧЁРНЫЙ СПИСОК
// ════════════════════════════════════════════════

model Blacklist {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  reason     String
  blockedById String   @map("blocked_by_id")
  // Расширенные данные
  violationType String? @map("violation_type")  // bypass_commission, fraud, abuse, spam
  evidence    String?                           // Доказательства (ссылки, скриншоты)
  address     String?                           // Адрес нарушителя
  city        String?                           // Город
  district    String?                           // Район
  telegramLocation String? @map("telegram_location") // Геолокация из Telegram
  penaltyAmount Decimal? @map("penalty_amount") @db.Decimal(12, 2) // Удержанная сумма
  orderId     String?  @map("order_id")         // Связанный заказ
  isPermanent Boolean  @default(true) @map("is_permanent")
  createdAt  DateTime  @default(now()) @map("created_at")
  expiresAt  DateTime? @map("expires_at")

  user      User @relation("BlockedUser", fields: [userId], references: [id])
  blockedBy User @relation("BlockedByUser", fields: [blockedById], references: [id])

  @@index([userId])
  @@index([violationType])
  @@map("blacklist")
}

