model AuditLog {
  id          String   @id @default(uuid())
  actorId     String   @map("actor_id")          // Кто выполнил действие
  action      String                              // ban_user, manual_balance, config_change, resolve_dispute, etc.
  entityType  String   @map("entity_type")        // User, Order, Payment, etc.
