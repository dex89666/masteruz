// ============================================
// MasterUz — Prisma Schema (PostgreSQL)
// Агент 1 (Архитектор) + Агент 3 (Бэкенд)
// ============================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Роли пользователей ───────────────────────
enum UserRole {
  CLIENT
  MASTER
  ADMIN
  MANAGER
}

// ─── Источник заказа ──────────────────────────
// DETAILED_WIZARD — клиент создал заказ через 4-шаговый визард (выбрал категорию, задачи, описание)
// INSTANT_AI      — клиент создал заказ через «Фото-заказ за 30 секунд» (фото + AI Vision)
enum OrderSource {
  DETAILED_WIZARD
  INSTANT_AI
}

// ─── Статусы заказа ───────────────────────────
enum OrderStatus {
  DRAFT
  PUBLISHED
  ACCEPTED
  IN_TRANSIT
  IN_PROGRESS
  AWAITING_REMAINDER   // Мастер подтвердил выполнение. Клиент выбирает способ оплаты остатка (CASH/CARD).
  COMPLETED
  CANCELLED
  DISPUTED
  // Статусы для оценки
  ESTIMATION_IN_PROGRESS  // Мастер едет на оценку
  ESTIMATION_DONE         // Оценка завершена, мастер составляет смету
  ESTIMATE_SENT           // Смета отправлена клиенту
  ESTIMATE_APPROVED       // Клиент согласился, ожидание модерации
  ESTIMATE_REJECTED       // Клиент отказался от сметы
  MODERATION              // Модерация сметы админом/менеджером
}

// ─── Уровни AI-варианта ──────────────────────
enum AiTier {
  GOOD
  BETTER
  BEST
}

// ─── Статусы сметы ────────────────────────────
enum EstimateStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  MODERATION
}

// ─── Статусы платежа ──────────────────────────
enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

// ─── Типы платежей ────────────────────────────
enum PaymentType {
  ORDER_COMMISSION
  ORDER_PAYMENT
  REFERRAL_BONUS
  SUBSCRIPTION
  REGISTRATION_FEE
  ESCROW_HOLD
  ESCROW_RELEASE
  PENALTY
  BALANCE_TOPUP
  VISIT_FEE
  ESTIMATION_FEE     // Плата за выезд на оценку
  ESTIMATE_PAYMENT   // Оплата по смете
}

// ─── Провайдеры платежей ──────────────────────
enum PaymentProvider {
  CLICK
  PAYME
  TELEGRAM_STARS
  INTERNAL
}

// ─── Статусы рефералов ────────────────────────
enum ReferralStatus {
  PENDING
  ACTIVE
  PAID
}

// ─── Типы рефералов ──────────────────────────
enum ReferralType {
  MASTER_TO_MASTER
  CLIENT_TO_CLIENT
}

// ─── Статусы откликов ─────────────────────────
enum ResponseStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

// ════════════════════════════════════════════════
// ПОЛЬЗОВАТЕЛИ
// ════════════════════════════════════════════════

model User {
  id          String   @id @default(uuid())
  telegramId  BigInt   @unique @map("telegram_id")
  username    String?
  phone       String?
  email       String?
  role        UserRole @default(CLIENT)
  isActive    Boolean  @default(true) @map("is_active")
  isVerified  Boolean  @default(false) @map("is_verified")
  balance     Decimal  @default(0) @db.Decimal(12, 2)
  // Язык интерфейса и уведомлений: 'ru' | 'uz' | 'en'.
  // Синхронизируется с выбором языка во фронтенде.
  language    String   @default("ru")
  referralCode String  @unique @map("referral_code")
  referredById String? @map("referred_by_id")
  // Customer Risk Score (0..100): чем выше — тем рискованнее клиент
  // 0–30 = надёжный, 31–60 = нейтральный, 61–80 = осторожно, 81+ = высокий риск
  riskScore     Int      @default(50) @map("risk_score")
  riskUpdatedAt DateTime? @map("risk_updated_at")
  riskFactors   Json?   @map("risk_factors") // снапшот факторов последнего пересчёта
  // Дисциплина мастера: накопление предупреждений за отмены ПОСЛЕ выезда
  // (статус IN_TRANSIT и далее). 4 warning → блок на 5 дней, счётчик в 0.
  warningCount   Int       @default(0)     @map("warning_count")
  blockedUntil   DateTime?                  @map("blocked_until")
  lastWarningAt  DateTime?                  @map("last_warning_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Связи
  referredBy     User?          @relation("UserReferrals", fields: [referredById], references: [id])
  referrals      User[]         @relation("UserReferrals")
  profile        UserProfile?
  masterProfile  MasterProfile?
  clientOrders   Order[]        @relation("ClientOrders")
  masterOrders   Order[]        @relation("MasterOrders")
  responses      OrderResponse[]
  reviewsGiven   Review[]       @relation("ReviewerReviews")
  reviewsReceived Review[]      @relation("RevieweeReviews")
  payments       Payment[]
  referralsGiven Referral[]     @relation("ReferrerReferrals")
  referralsReceived Referral[]  @relation("ReferredReferrals")
  certificates   Certificate[]
  courseProgress  CourseProgress[]
  notifications  Notification[]
  blacklistEntries Blacklist[]  @relation("BlockedUser")
  blacklistActions Blacklist[]  @relation("BlockedByUser")
  configUpdates  PlatformConfig[] @relation("ConfigUpdater")
  chatMessages   ChatMessage[]
  favoriteMasters FavoriteMaster[] @relation("ClientFavorites")
  favoritedBy    FavoriteMaster[] @relation("MasterFavorites")
  usedPromoCodes PromoCodeUsage[]
  portfolioItems PortfolioItem[] @relation("MasterPortfolio")
  balanceTransactions BalanceTransaction[]
  storeReviews   StoreReview[]
  turnkeyProjects TurnkeyProject[]
  estimates      Estimate[]     @relation("EstimateMaster")
  priceChangeRequests PriceChangeRequest[] @relation("PriceChangeMaster")
  aiOrderTemplates AiOrderTemplate[]
  supportChatsAsUser  SupportChat[]    @relation("SupportChatUser")
  supportChatsAsAdmin SupportChat[]    @relation("SupportChatAdmin")
  supportMessages     SupportMessage[] @relation("SupportMsgSender")
  auditLogs           AuditLog[]
  forumTopics         ForumTopic[]     @relation("ForumTopicAuthor")
  forumPosts          ForumPost[]      @relation("ForumPostAuthor")
  linkedCards         LinkedCard[]
  savedCards          SavedCard[]
  clientReviewsGiven    MasterReviewClient[] @relation("MRC_Master")
  clientReviewsReceived MasterReviewClient[] @relation("MRC_Client")
  masterSubscriptions   MasterSubscription[] @relation("MasterSubscriptions")
  referredSubscriptions MasterSubscription[] @relation("ReferrerSubscriptions")
  warnings              MasterWarning[]      @relation("UserWarnings")
  privilegedProfile     PrivilegedOfficialProfile?
  approverForOfficials  PrivilegedOfficialProfile[] @relation("OfficialApprover")

  @@map("users")
}

// ════════════════════════════════════════════════
// ДИСЦИПЛИНА МАСТЕРА — история предупреждений
// ════════════════════════════════════════════════
//
// Каждый раз, когда мастер отменяет заказ ПОСЛЕ нажатия «Выехал»
// (статус IN_TRANSIT и далее), создаётся запись. Счётчик User.warningCount
// растёт; на 4-м warning — блокировка 5 дней и сброс счётчика.
model MasterWarning {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  orderId       String?   @map("order_id")
  reason        String                                              // 'CANCEL_AFTER_TRANSIT'
  penaltyAmount Decimal   @default(0) @map("penalty_amount") @db.Decimal(12, 2)
  warningNo     Int       @map("warning_no")                        // 1..4 в текущем цикле
  blockedUntil  DateTime? @map("blocked_until")                      // если этот warning вызвал блок
  createdAt     DateTime  @default(now()) @map("created_at")

  user User @relation("UserWarnings", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("master_warnings")
}

// ════════════════════════════════════════════════
// ПРИВЯЗАННЫЕ КАРТЫ (для выплат мастерам и оплаты клиентами)
// ════════════════════════════════════════════════

model LinkedCard {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  cardNumber   String   @map("card_number")   // Маскированный: 8600 **** **** 1234
  cardHolder   String?  @map("card_holder")   // Имя держателя
  expiryMonth  Int?     @map("expiry_month")
  expiryYear   Int?     @map("expiry_year")
  provider     String   @default("UZCARD")    // UZCARD, HUMO, VISA, MASTERCARD
  isDefault    Boolean  @default(false) @map("is_default")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("linked_cards")
}

// Привязанные карты для Payme Subscribe API (token-based)
model SavedCard {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  token       String   @unique
  lastFour    String   @map("last_four")
  brand       String?  @map("brand")
  expiryMonth Int?     @map("expiry_month")
  expiryYear  Int?     @map("expiry_year")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_cards")
}

model UserProfile {
  id        String  @id @default(uuid())
  userId    String  @unique @map("user_id")
  firstName String  @map("first_name")
  lastName  String? @map("last_name")
  avatarUrl String? @map("avatar_url")
  bio       String?
  latitude  Float?
  longitude Float?
  address   String?
  city      String?
  district  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model MasterProfile {
  id              String    @id @default(uuid())
  userId          String    @unique @map("user_id")
  specializations String[]  @default([])
  experienceYears Int       @default(0) @map("experience_years")
  rating          Float     @default(0)
  completedOrders Int       @default(0) @map("completed_orders")
  isAvailable     Boolean   @default(true) @map("is_available")
  isOnline        Boolean   @default(false) @map("is_online")
  lastSeenAt      DateTime? @map("last_seen_at")
  maxDistanceKm   Int       @default(10) @map("max_distance_km")
  hourlyRate      Decimal?  @map("hourly_rate") @db.Decimal(12, 2)
  schoolCompleted  Boolean   @default(false) @map("school_completed")
  registrationPaid Boolean   @default(false) @map("registration_paid")
  registrationPaidAt DateTime? @map("registration_paid_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  masterCategories MasterCategory[]

  @@map("master_profiles")
}

model Certificate {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  title      String
  fileUrl    String   @map("file_url")
  verified   Boolean  @default(false)
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

// ════════════════════════════════════════════════
// КАТЕГОРИИ УСЛУГ
// ════════════════════════════════════════════════

model Category {
  id        String    @id @default(uuid())
  name      String
  nameUz    String?   @map("name_uz")
  nameEn    String?   @map("name_en")
  slug      String    @unique
  icon      String?
  parentId  String?   @map("parent_id")
  sortOrder Int       @default(0) @map("sort_order")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")

  parent        Category?      @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children      Category[]     @relation("CategoryHierarchy")
  orders        Order[]
  courses       SchoolCourse[]
  subcategories Subcategory[]
  portfolioItems PortfolioItem[] @relation("PortfolioCategory")
  masterCategories MasterCategory[]
  knowledgeEntries KnowledgeEntry[]

  @@map("categories")
}

// ════════════════════════════════════════════════
// СВЯЗЬ МАСТЕРОВ С КАТЕГОРИЯМИ (M:N)
// ════════════════════════════════════════════════

model MasterCategory {
  id              String   @id @default(uuid())
  masterProfileId String   @map("master_profile_id")
  categoryId      String   @map("category_id")
  createdAt       DateTime @default(now()) @map("created_at")

  masterProfile MasterProfile @relation(fields: [masterProfileId], references: [id], onDelete: Cascade)
  category      Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([masterProfileId, categoryId])
  @@index([categoryId])
  @@map("master_categories")
}

// ════════════════════════════════════════════════
// ПОДКАТЕГОРИИ УСЛУГ
// ════════════════════════════════════════════════

model Subcategory {
  id         String   @id @default(uuid())
  categoryId String   @map("category_id")
  name       String
  nameUz     String?  @map("name_uz")
  nameEn     String?  @map("name_en")
  slug       String   @unique
  icon       String?
  sortOrder  Int      @default(0) @map("sort_order")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tasks    Task[]

  @@index([categoryId])
  @@map("subcategories")
}

// ════════════════════════════════════════════════
// ЗАДАЧИ (КОНКРЕТНЫЕ ВИДЫ РАБОТ)
// ════════════════════════════════════════════════

model Task {
  id             String   @id @default(uuid())
  subcategoryId  String   @map("subcategory_id")
  name           String
  nameUz         String?  @map("name_uz")
  nameEn         String?  @map("name_en")
  description    String?
  descriptionUz  String?  @map("description_uz")
  descriptionEn  String?  @map("description_en")
  estimatedTime  String?  @map("estimated_time")          // e.g. "30-60 мин"
  estimatedTimeUz String? @map("estimated_time_uz")
  estimatedTimeEn String? @map("estimated_time_en")
  minPrice       Decimal? @map("min_price") @db.Decimal(12, 2)  // Минимальная цена (сум), e.g. 150000
  slug           String   @unique
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  subcategory Subcategory  @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  orderTasks  OrderTask[]

  @@index([subcategoryId])
  @@map("tasks")
}

// ════════════════════════════════════════════════
// СВЯЗЬ ЗАКАЗОВ С ЗАДАЧАМИ (M:N)
// ════════════════════════════════════════════════

model OrderTask {
  id      String @id @default(uuid())
  orderId String @map("order_id")
  taskId  String @map("task_id")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  task  Task  @relation(fields: [taskId], references: [id])

  @@unique([orderId, taskId])
  @@map("order_tasks")
}

// ════════════════════════════════════════════════
// ЗАКАЗЫ (ЛОТЫ)
// ════════════════════════════════════════════════

model Order {
  id               String      @id @default(uuid())
  clientId         String      @map("client_id")
  masterId         String?     @map("master_id")
  categoryId       String      @map("category_id")
  title            String
  description      String
  price            Decimal     @db.Decimal(12, 2)
  priceMax         Decimal?    @map("price_max") @db.Decimal(12, 2)
  commissionRate   Decimal     @map("commission_rate") @db.Decimal(5, 2)
  commissionAmount Decimal     @map("commission_amount") @db.Decimal(12, 2)
  status           OrderStatus @default(DRAFT)
  isUrgent         Boolean     @default(false) @map("is_urgent")
  urgentMultiplier Float       @default(1.0) @map("urgent_multiplier")
  commissionPaid   Boolean     @default(false) @map("commission_paid")
  // Anti-fraud: Escrow / подтверждения / штрафы
  visitFee         Decimal?    @map("visit_fee") @db.Decimal(12, 2)
  escrowAmount     Decimal     @default(0) @map("escrow_amount") @db.Decimal(12, 2)
  // ─── Модель оплаты ──────────────────────────────────────────────
  // FULL_ESCROW  — legacy: клиент при создании блокирует 100% суммы.
  // DEPOSIT_30   — клиент платит депозит при создании (по умолчанию 30%),
  //                остаток выбирает при завершении: наличными мастеру (CASH)
  //                или списать с баланса (CARD). Комиссия платформы всегда
  //                уже включена в депозит — мастер ничего не должен.
  paymentModel     String      @default("DEPOSIT_30") @map("payment_model")
  depositAmount    Decimal     @default(0) @map("deposit_amount") @db.Decimal(12, 2)
  remainingAmount  Decimal     @default(0) @map("remaining_amount") @db.Decimal(12, 2)
  remainderMethod  String?     @map("remainder_method")     // 'CASH' | 'CARD'
  remainderPaidAt  DateTime?   @map("remainder_paid_at")
  offerAccepted    Boolean     @default(false) @map("offer_accepted")
  masterConfirmedAt DateTime?  @map("master_confirmed_at")
  clientConfirmedAt DateTime?  @map("client_confirmed_at")
  acceptedAt       DateTime?   @map("accepted_at")
  inTransitAt      DateTime?   @map("in_transit_at")
  // Подтверждение выезда мастера: причина и обещанное время прибытия
  transitReason    String?     @map("transit_reason")        // 'MATERIAL' | 'TO_CLIENT'
  transitEtaAt     DateTime?   @map("transit_eta_at")        // когда мастер обещал быть
  lastMasterPingAt DateTime?   @map("last_master_ping_at")   // анти-спам для cron-напоминаний
  // Live-позиция мастера во время доставки (обновляется с фронта раз в ~10с)
  masterLat        Float?      @map("master_lat")
  masterLng        Float?      @map("master_lng")
  masterLocationAt DateTime?   @map("master_location_at")
  penaltyAmount    Decimal     @default(0) @map("penalty_amount") @db.Decimal(12, 2)
  cancelReason     String?     @map("cancel_reason")
  cancelledBy      String?     @map("cancelled_by")
  disputeReason    String?     @map("dispute_reason")
  // Счётчик отправленных напоминаний мастерам перед авто-отменой (0..3)
  remindersSent    Int         @default(0) @map("reminders_sent")
  // Оценка (выезд мастера)
  isEstimationOrder Boolean    @default(false) @map("is_estimation_order")
  estimationFee    Decimal?    @map("estimation_fee") @db.Decimal(12, 2) // 150 000 сум
  parentOrderId    String?     @map("parent_order_id")        // Связь: заказ оценки → основной заказ
  // AI Instant Order (ФотоЗаказ за 30 сек)
  isInstantAiOrder Boolean     @default(false) @map("is_instant_ai_order")
  source           OrderSource @default(DETAILED_WIZARD)
  aiTemplateId     String?     @map("ai_template_id")
  additionalWishes String?     @map("additional_wishes")
  moderationRequired Boolean   @default(false) @map("moderation_required")
  voiceDescription String?     @map("voice_description")      // Текстовая расшифровка голоса
  // Комментарий админа
  adminComment     String?     @map("admin_comment")
  // Geo / адрес
  latitude         Float?
  longitude        Float?
  address          String?
  street           String?
  city             String?
  district         String?
  region           String?
  deadline         DateTime?
  images           String[]    @default([])
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  completedAt      DateTime?   @map("completed_at")
  cancelledAt      DateTime?   @map("cancelled_at")

  // ─── RAG: самообучаемый поиск решений ──────────────────────────
  // Прямого поля Prisma не делаем — pgvector тип нативно не
  // поддерживается. Поиск выполняется через `prisma.$queryRaw`,
  // запись — через тот же raw-канал. Здесь объявляем поле
  // как Unsupported, чтобы Prisma не дропнула колонку при `db push`.
  embedding          Unsupported("vector(1536)")? 
  embeddingUpdatedAt DateTime? @map("embedding_updated_at")

  client     User            @relation("ClientOrders", fields: [clientId], references: [id])
  master     User?           @relation("MasterOrders", fields: [masterId], references: [id])
  category   Category        @relation(fields: [categoryId], references: [id])
  responses  OrderResponse[]
  reviews    Review[]
  payments   Payment[]
  orderTasks OrderTask[]
  chatMessages ChatMessage[]
  photos     OrderPhoto[]
  guarantee  Guarantee?
  estimates  Estimate[]
  parentOrder Order?         @relation("EstimationChain", fields: [parentOrderId], references: [id])
  childOrders Order[]        @relation("EstimationChain")
  aiTemplate  AiOrderTemplate? @relation(fields: [aiTemplateId], references: [id])
  masterClientReviews MasterReviewClient[]
  priceChangeRequests PriceChangeRequest[]

  @@index([status, createdAt])
  @@index([latitude, longitude])
  @@index([categoryId])
  @@index([clientId])
  @@index([masterId])
  @@index([clientId, status])
  @@index([masterId, status])
  @@index([aiTemplateId])
  @@index([source])
  @@index([status, transitEtaAt])
  @@index([status, masterLocationAt])
  @@map("orders")
}

model OrderResponse {
  id         String         @id @default(uuid())
  orderId    String         @map("order_id")
  masterId   String         @map("master_id")
  priceOffer Decimal?       @map("price_offer") @db.Decimal(12, 2)
  message    String?
  status     ResponseStatus @default(PENDING)
  createdAt  DateTime       @default(now()) @map("created_at")

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  master User  @relation(fields: [masterId], references: [id])

  @@unique([orderId, masterId])
  @@map("order_responses")
}

// ════════════════════════════════════════════════
// ОТЗЫВЫ И РЕЙТИНГИ
// ════════════════════════════════════════════════

model Review {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  reviewerId String   @map("reviewer_id")
  revieweeId String   @map("reviewee_id")
  rating     Int      // 1-5
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")

  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewer User  @relation("ReviewerReviews", fields: [reviewerId], references: [id])
  reviewee User  @relation("RevieweeReviews", fields: [revieweeId], references: [id])

  @@unique([orderId, reviewerId])
  @@index([revieweeId])
  @@map("reviews")
}

// ════════════════════════════════════════════════
// ОТЗЫВЫ МАСТЕРОВ О КЛИЕНТАХ (для Customer Risk Score)
// ════════════════════════════════════════════════
// Мастер после завершения/отмены заказа может оценить клиента
// по нескольким осям. Это влияет на riskScore клиента.
model MasterReviewClient {
  id             String   @id @default(uuid())
  orderId        String   @map("order_id")
  masterId       String   @map("master_id")
  clientId       String   @map("client_id")
  // 1..5: общая адекватность клиента
  overall        Int
  // Опциональные флаги (для скоринга)
  wasRude        Boolean  @default(false) @map("was_rude")        // хамил, грубил
  wasNoShow      Boolean  @default(false) @map("was_no_show")     // не открыл / не пришёл
  haggledHard    Boolean  @default(false) @map("haggled_hard")    // торговался после согласования
  changedScope   Boolean  @default(false) @map("changed_scope")   // менял ТЗ по ходу
  delayedPayment Boolean  @default(false) @map("delayed_payment") // тянул оплату
  comment        String?
  createdAt      DateTime @default(now()) @map("created_at")

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  master User  @relation("MRC_Master", fields: [masterId], references: [id])
  client User  @relation("MRC_Client", fields: [clientId], references: [id])

  @@unique([orderId, masterId])
  @@index([clientId])
  @@map("master_reviews_client")
}

// ════════════════════════════════════════════════
// PRO-ПОДПИСКА МАСТЕРА
// ════════════════════════════════════════════════
// Активная подписка = currentPeriodEnd > now() AND status = ACTIVE.
// Trial учитывается отдельно (plan = TRIAL).
// Все алгоритмы (top-выдача, 0% комиссия, приоритетный пуш)
// делают `getActiveMasterSubscription(userId)` и решают по результату.

enum MasterPlan {
  TRIAL       // 14 дней при регистрации, бесплатно
  MONTH       // 99 000 сум / 30 дней
  QUARTER     // 249 000 сум / 90 дней
  FIVE_MONTH  // 300 000 сум / 150 дней — флагман
  YEAR        // 590 000 сум / 365 дней
  REFERRAL    // +30 дней за приведённого мастера (бесплатно)
  FOUNDER     // Founder pricing — первые 1000 мастеров
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  REFUNDED
}

model MasterSubscription {
  id                 String              @id @default(uuid())
  masterId           String              @map("master_id")
  plan               MasterPlan
  status             SubscriptionStatus  @default(ACTIVE)
  // Период действия (UTC, end = exclusive)
  currentPeriodStart DateTime            @map("current_period_start")
  currentPeriodEnd   DateTime            @map("current_period_end")
  // Сколько уплачено (для trial/referral = 0)
  amountPaid         Decimal             @default(0) @map("amount_paid") @db.Decimal(12, 2)
  // Связь с платежом (если был)
  paymentId          String?             @unique @map("payment_id")
  // Кто привёл (для REFERRAL-плана)
  referrerMasterId   String?             @map("referrer_master_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  master   User     @relation("MasterSubscriptions", fields: [masterId], references: [id], onDelete: Cascade)
  payment  Payment? @relation(fields: [paymentId], references: [id])
  referrer User?    @relation("ReferrerSubscriptions", fields: [referrerMasterId], references: [id])

  @@index([masterId, status, currentPeriodEnd])
  @@index([currentPeriodEnd])
  @@map("master_subscriptions")
}

// ════════════════════════════════════════════════
// ПЛАТЕЖИ
// ════════════════════════════════════════════════

model Payment {
  id            String          @id @default(uuid())
  orderId       String?         @map("order_id")
  userId        String          @map("user_id")
  amount        Decimal       @db.Decimal(12, 2)
  type          PaymentType
  provider      PaymentProvider
  providerTxId  String?         @unique @map("provider_tx_id")
  status        PaymentStatus   @default(PENDING)
  metadata      Json?
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  order Order? @relation(fields: [orderId], references: [id])
  user  User   @relation(fields: [userId], references: [id])
  masterSubscription MasterSubscription?
  paymeTransactions  PaymentTransaction[]

  @@index([status])
  @@index([userId, createdAt])
  @@index([provider, providerTxId])
  @@map("payments")
}

// ════════════════════════════════════════════════
// ИЗМЕНЕНИЕ ЦЕНЫ ПО ХОДУ РАБОТ
// ════════════════════════════════════════════════

// Что именно предлагает мастер.
enum PriceChangeKind {
  PRICE_CHANGE // новая цена работ (доп. работы / уточнение объёма)
  SETTLEMENT   // расчёт при отказе клиента: фактически выполненная работа
}

enum PriceChangeStatus {
  PENDING    // ждёт решения клиента
  MODERATION // рост выше лимита → сначала решает админ
  APPROVED   // клиент (и админ, если требовалось) согласился
  REJECTED   // клиент отказался
  CANCELLED  // мастер отозвал предложение
}

// Предложение мастера изменить цену заказа по ходу работ.
// Любое изменение требует ЯВНОГО подтверждения клиента (см. priceChangeLimitPct).
// При отказе клиента создаётся запись с kind=SETTLEMENT: мастер заявляет
// фактически выполненный объём, клиент подтверждает либо открывает спор.
model PriceChangeRequest {
  id            String            @id @default(uuid())
  orderId       String            @map("order_id")
  masterId      String            @map("master_id")
  kind          PriceChangeKind   @default(PRICE_CHANGE)
  status        PriceChangeStatus @default(PENDING)
  oldPrice      Decimal           @map("old_price") @db.Decimal(12, 2) // цена работ до изменения
  newPrice      Decimal           @map("new_price") @db.Decimal(12, 2) // предлагаемая цена работ
  reason        String                                                  // обоснование (обязательно)
  photos        String[]          @default([])                          // фото-доказательства
  // Модерация (если рост выше priceChangeLimitPct)
  moderatedById String?           @map("moderated_by_id")
  moderatedAt   DateTime?         @map("moderated_at")
  moderatorNote String?           @map("moderator_note")
  respondedAt   DateTime?         @map("responded_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  master User  @relation("PriceChangeMaster", fields: [masterId], references: [id])

  @@index([orderId])
  @@index([status])
  @@index([orderId, status])
  @@map("price_change_requests")
}

// ─── Транзакции протокола Payme Merchant API ──────────────────────
// Хранит состояние транзакции Payme отдельно от нашего Payment, т.к.
// протокол требует стабильных create_time/perform_time/cancel_time и
// собственную машину состояний (1, 2, -1, -2) для методов
// CheckTransaction / GetStatement / идемпотентности.
model PaymentTransaction {
  id          String    @id @default(uuid())
  paymeId     String    @unique @map("payme_id")   // params.id, присланный Payme
  paymentId   String    @map("payment_id")          // наш Payment.id (account.payment_id)
  amount      Decimal   @db.Decimal(16, 2)          // сумма в тийинах
  state       Int       @default(1)                  // 1 создана, 2 проведена, -1 отменена до, -2 отменена после
  reason      Int?                                    // код причины отмены (Payme)
  createTime  DateTime  @map("create_time")          // из params.time (мс с эпохи)
  performTime DateTime? @map("perform_time")
  cancelTime  DateTime? @map("cancel_time")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  payment Payment @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@index([createTime])
  @@index([state])
  @@map("payment_transactions")
}

// ════════════════════════════════════════════════
// РЕФЕРАЛЬНАЯ СИСТЕМА
// ════════════════════════════════════════════════

model Referral {
  id          String         @id @default(uuid())
  referrerId  String         @map("referrer_id")
  referredId  String         @map("referred_id")
  type        ReferralType
  bonusAmount Decimal?       @map("bonus_amount") @db.Decimal(12, 2)
  bonusRate   Decimal         @map("bonus_rate") @db.Decimal(5, 2)
  status      ReferralStatus @default(PENDING)
  createdAt   DateTime       @default(now()) @map("created_at")

  referrer User @relation("ReferrerReferrals", fields: [referrerId], references: [id])
  referred User @relation("ReferredReferrals", fields: [referredId], references: [id])

  @@unique([referrerId, referredId])
  @@map("referrals")
}

