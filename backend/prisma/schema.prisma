// ════════════════════════════════════════════════
// ТРАНЗАКЦИИ БАЛАНСА (аудит-лог движения средств)
// ════════════════════════════════════════════════

enum BalanceTransactionType {
  TOPUP           // Пополнение баланса
  ESCROW_HOLD     // Блокировка средств при создании заказа (legacy / DEPOSIT_HOLD теперь предпочтительнее)
  ESCROW_RELEASE  // Разблокировка / перевод мастеру
  DEPOSIT_HOLD    // Блокировка депозита 30% при создании заказа
  REMAINDER_PAYMENT // Доплата клиентом остатка 70% картой при завершении
  PENALTY         // Штраф за отмену
  FALSE_DISPUTE_PENALTY // Штраф клиенту за ложный диспут (наличку получил, но отказался)
  REFUND          // Возврат средств
  COMMISSION      // Оплата комиссии
  PAYOUT          // Выплата мастеру
  ESTIMATION_FEE  // Оплата за выезд на оценку
  ESTIMATE_PAYOUT // Выплата мастеру за оценку
  ADMIN_TOPUP     // Админское зачисление средств
  ADMIN_WITHDRAW  // Админское списание средств
  REFERRAL_BONUS  // Реферальный бонус
}

model BalanceTransaction {
  id            String                @id @default(uuid())
  userId        String                @map("user_id")
  type          BalanceTransactionType
  amount        Decimal               @db.Decimal(12, 2) // Сумма (положительная — приход, отрицательная — расход)
  balanceBefore Decimal               @map("balance_before") @db.Decimal(12, 2)
  balanceAfter  Decimal               @map("balance_after") @db.Decimal(12, 2)
  orderId       String?               @map("order_id")
  description   String?
  metadata      Json?
  createdAt     DateTime              @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, type])
  @@index([orderId])
  @@map("balance_transactions")
}

// ════════════════════════════════════════════════
// АУДИТ-ЛОГ АДМИНИСТРАТИВНЫХ ДЕЙСТВИЙ
