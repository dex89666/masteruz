# ============================================
# MasterUz Backend — Переменные окружения
# ============================================

# Сервер
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# База данных PostgreSQL
DATABASE_URL="postgresql://masteruz:masteruz_secret@localhost:5432/masteruz_db?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_REFRESH_EXPIRES_IN="30d"

# Telegram Bot
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
TELEGRAM_BOT_USERNAME="MasterUzBot"
TELEGRAM_MINI_APP_URL="https://your-domain.com"

# Yandex Maps API
YANDEX_MAPS_API_KEY="YOUR_YANDEX_MAPS_API_KEY"

# Платежные системы — Click
CLICK_MERCHANT_ID="YOUR_CLICK_MERCHANT_ID"
CLICK_SERVICE_ID="YOUR_CLICK_SERVICE_ID"
CLICK_SECRET_KEY="YOUR_CLICK_SECRET_KEY"

# Платежные системы — Payme
PAYME_MERCHANT_ID="YOUR_PAYME_MERCHANT_ID"
PAYME_MERCHANT_KEY="YOUR_PAYME_MERCHANT_KEY"

# Загрузка файлов
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880

# Vercel Blob Storage (только для serverless-деплоя)
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ImgBB — резервный хостинг картинок (опционально, для serverless)
# IMGBB_API_KEY="your_imgbb_api_key"

# Upstash Redis (только для serverless — Vercel/Cloudflare)
# UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your_upstash_token"

# Конфигурация платформы (по умолчанию)
DEFAULT_COMMISSION_RATE=15
MASTER_REGISTRATION_FEE=400000
DEFAULT_REFERRAL_MASTER_BONUS_RATE=5
DEFAULT_REFERRAL_CLIENT_DISCOUNT_RATE=3

# Telegram — уведомления администратору
# ADMIN_TELEGRAM_CHAT_ID="your_admin_chat_id"

# CORS
CORS_ORIGIN="http://localhost:5173"

# Суперадмины (username через запятую, НЕ хардкодить в коде!)
SUPER_ADMIN_USERNAMES="your_telegram_username"

# Логирование
LOG_LEVEL="debug"
