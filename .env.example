# ════════════════════════════════════════════════════════════════════
# MasterUz — Шаблон переменных окружения
# Скопируй этот файл в .env (cp .env.example .env) и заполни значения.
# ВСЕ переменные хранятся в ОДНОМ файле .env (корень репо).
# backend/.env и frontend/.env — это симлинки на ../.env.
# ════════════════════════════════════════════════════════════════════

# ──────── Среда выполнения ────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=debug

# ──────── База данных ────────
DATABASE_URL=postgresql://user:password@localhost:5432/masteruz
DB_PASSWORD=

# ──────── Redis ────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ──────── JWT (генерировать через openssl rand -hex 64) ────────
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ──────── Telegram Bot (получить у @BotFather) ────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=
TELEGRAM_BOT_USERNAME=
TELEGRAM_MINI_APP_URL=http://localhost:5173
ADMIN_TELEGRAM_CHAT_ID=

# ──────── Yandex Maps ────────
YANDEX_MAPS_API_KEY=

# ──────── Платёжные системы ────────
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=

# ──────── Загрузки ────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ──────── Платформа ────────
SUPER_ADMIN_USERNAMES=
DEFAULT_COMMISSION_RATE=15

# ════════════════════════════════════════════════════════════════════
#                 К О М А Н Д А   /   А Л Е Р Т Ы
# ────────────────────────────────────────────────────────────────────
# Перечисли Telegram-никнеймы (без @) через запятую — кому какой алерт.
# Один человек может быть в нескольких ролях. Регистр игнорируется.
#
#   OWNER       — владельцы продукта. Только критические системные
#                 алерты: AI quota / Redis down / DB error / бэкапы.
#   DISPATCHER  — диспетчеры заказов. Висящие заказы без мастера,
#                 мастер не выехал, опоздание по ETA, отмены в транзите.
#   SUPPORT     — техподдержка. Жалобы клиентов и мастеров, споры,
#                 тикеты, эскалации из чата заказов.
#   FINANCE     — финансы. Failed-платежи, возвраты, эскроу > порога,
#                 чарджбэки, расхождения баланса.
#   MODERATOR   — модерация контента. Зафлаганные сообщения чата,
#                 фото-нарушения, форум-репорты.
#
# Пример: ROLE_OWNER_USERNAMES=vlad,dex89666
ROLE_OWNER_USERNAMES=
ROLE_DISPATCHER_USERNAMES=
ROLE_SUPPORT_USERNAMES=
ROLE_FINANCE_USERNAMES=
ROLE_MODERATOR_USERNAMES=
# ════════════════════════════════════════════════════════════════════

MASTER_REGISTRATION_FEE=400000
DEFAULT_REFERRAL_MASTER_BONUS_RATE=5
DEFAULT_REFERRAL_CLIENT_DISCOUNT_RATE=3

# ──────── CORS ────────
CORS_ORIGIN=http://localhost:5173

# ──────── Sentry (backend) ────────
SENTRY_DSN=

# ──────── Хранилище файлов (uploads) ────────
# local — диск контейнера (по умолчанию, теряется при редеплое)
# s3    — Cloudflare R2 / Backblaze B2 / AWS S3
STORAGE_DRIVER=local
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# ════════════════════════════════════════════════════════════════════
#                    F R O N T E N D   ( V I T E )
# ════════════════════════════════════════════════════════════════════
VITE_API_URL=/api
VITE_TELEGRAM_BOT_NAME=
VITE_YANDEX_MAPS_KEY=
VITE_YM_COUNTER=
VITE_SENTRY_DSN=
