# ============================================
# MasterUz — Production Environment Template
# Скопируйте в .env.production и заполните ВСЕ значения
#
# Генерация секретов:
#   openssl rand -hex 32   # для DB/Redis паролей
#   openssl rand -hex 64   # для JWT секретов
# ============================================

# ─── Домен (без https://) ───────────────────
DOMAIN=masteruz.uz

# ─── База данных ────────────────────────────
DB_PASSWORD=СГЕНЕРИРУЙ_openssl_rand_hex_32

# ─── Redis ──────────────────────────────────
REDIS_PASSWORD=СГЕНЕРИРУЙ_openssl_rand_hex_32

# ─── JWT (УНИКАЛЬНЫЕ, НИКОГДА не переиспользовать!) ──
JWT_SECRET=СГЕНЕРИРУЙ_openssl_rand_hex_64
JWT_REFRESH_SECRET=СГЕНЕРИРУЙ_ДРУГОЙ_openssl_rand_hex_64
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── Telegram Bot (от @BotFather) ───────────
TELEGRAM_BOT_TOKEN=1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_USERNAME=MasterUzBot

# ─── Yandex Maps (developer.tech.yandex.ru) ─
YANDEX_MAPS_API_KEY=

# ─── Click (после договора с merchant.click.uz) ──
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# ─── Payme (после договора с business.payme.uz) ──
PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=

# ─── Суперадмины (Telegram username без @, через запятую) ──
SUPER_ADMIN_USERNAMES=yourusername

# ─── Telegram chat для уведомлений (через @userinfobot) ──
ADMIN_TELEGRAM_CHAT_ID=

# ─── CORS (обязательно https://) ────────────
CORS_ORIGIN=https://masteruz.uz

# ─── Загрузки ───────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=5242880

# ─── Платформа ──────────────────────────────
DEFAULT_COMMISSION_RATE=15
MASTER_REGISTRATION_FEE=400000
DEFAULT_REFERRAL_MASTER_BONUS_RATE=5
DEFAULT_REFERRAL_CLIENT_DISCOUNT_RATE=3

# ─── Логи ───────────────────────────────────
LOG_LEVEL=warn
NODE_ENV=production
