# ============================================
# MasterUz — Production Environment Template
# Скопируйте в .env.production и заполните ВСЕ значения
# ============================================

# ─── ДОМЕН ──────────────────────────────────
DOMAIN=masteruz.uz

# ─── БАЗА ДАННЫХ ────────────────────────────
DB_PASSWORD=СГЕНЕРИРУЙ_СЛОЖНЫЙ_ПАРОЛЬ_32_СИМВОЛА

# ─── REDIS ──────────────────────────────────
REDIS_PASSWORD=СГЕНЕРИРУЙ_СЛОЖНЫЙ_ПАРОЛЬ_24_СИМВОЛА

# ─── JWT (ОБЯЗАТЕЛЬНО УНИКАЛЬНЫЕ!) ──────────
JWT_SECRET=СГЕНЕРИРУЙ_СЕКРЕТ_64_СИМВОЛА
JWT_REFRESH_SECRET=СГЕНЕРИРУЙ_ДРУГОЙ_СЕКРЕТ_64_СИМВОЛА

# ─── TELEGRAM BOT ───────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_USERNAME=MasterUzBot

# ─── YANDEX MAPS ────────────────────────────
YANDEX_MAPS_API_KEY=ваш_ключ_yandex_maps

# ─── CLICK (Платёжная система) ──────────────
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# ─── PAYME (Платёжная система) ──────────────
PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=

# ─── CORS ───────────────────────────────────
CORS_ORIGIN=https://masteruz.uz
