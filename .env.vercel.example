# ============================================
# MasterUz — Переменные окружения для Vercel
# Все переменные вводятся в Vercel Dashboard → Settings → Environment Variables
# ============================================

# ─── ОБЯЗАТЕЛЬНЫЕ ────────────────────────────────

# PostgreSQL (Neon — бесплатный tier)
# Формат: postgresql://user:password@ep-xxx.region.aws.neon.tech/masteruz?sslmode=require
DATABASE_URL=postgresql://neondb_owner:xxx@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Redis (Upstash — бесплатный tier)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxxxx

# JWT секреты (сгенерируйте: openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars

# Telegram Bot
TELEGRAM_BOT_TOKEN=1234567890:AAF-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_USERNAME=MasterUzBot

# CORS (ваш домен на Vercel)
CORS_ORIGIN=https://masteruz.vercel.app

# ─── ОПЦИОНАЛЬНЫЕ ───────────────────────────────

# Vercel Blob (для загрузки файлов, бесплатно до 500MB)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# Yandex Maps
YANDEX_MAPS_API_KEY=

# Платежи (Click)
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# Платежи (Payme)
PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=

# ─── АВТОМАТИЧЕСКИЕ (Vercel сам установит) ───────

# VERCEL=1          ← Vercel устанавливает автоматически
# NODE_ENV=production ← Устанавливается автоматически
